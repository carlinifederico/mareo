{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git",
      ".git/**",
      ".firebase",
      ".firebase/**",
      ".claude",
      ".claude/**",
      ".vscode",
      ".vscode/**",
      "**/.*",
      "**/node_modules/**",
      "_MAT",
      "_MAT/**",
      "data",
      "data/**",
      "dev-server.py",
      "fb-login-helper.py",
      "backup-firestore.py",
      "restore-firestore.py",
      ".fb_url.txt",
      ".fb_code.txt",
      ".fb_result.log",
      "*.md",
      "**/*.md",
      ".gitignore"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/js/**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "/css/**",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      }
    ]
  }
}
